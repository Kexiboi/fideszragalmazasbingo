# Helyi fejlesztés (npm run dev): localhost
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bingo"

# Docker Compose `web` szolgáltatás: a compose felülírja a DATABASE_URL-t (host: db).
# AUTH_URL: böngészőből elért cím (NextAuth / Auth.js callback-ekhez)
AUTH_URL="http://localhost:3000"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
ADMIN_EMAIL="admin@localhost"
ADMIN_PASSWORD="change-this-in-production"
